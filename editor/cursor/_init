#!/usr/bin/env zsh
source ${0:A:h}/../../deploy

AGENT_CONFIG="${HOME}/dev/eduarbo/agent-config"

link() {
  if [[ ! -d "$AGENT_CONFIG" ]]; then
    echo-fail "agent-config repo not found at $AGENT_CONFIG"
    echo-info "Clone it first: git clone git@github.com:eduarbo/agent-config.git $AGENT_CONFIG"
    return 1
  fi

  echo-info "Running agent-config setup..."
  "$AGENT_CONFIG/setup"
}

install() {
  link
}

update() {
  link
}

clean() {
  rm -fv "$HOME/.cursor/skills/pre-pr-review"
  rm -fv "$HOME/.cursor/skills/spec-driven-dev"
}

init "$@"
