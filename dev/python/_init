#!/usr/bin/env zsh
source ${0:A:h}/../../deploy
source env.zsh

# Tools installed globally via pipx (isolated envs, no venv conflicts)
pipx_deps=(
  "python-lsp-server[all]"
)

# Tools available as system packages (prefer brew/apt over pip)
brew_deps=(
  ruff    # linter + formatter (replaces pyflakes, black, isort)
  pipx    # installs Python CLI apps in isolated environments
)

# Build dependencies required by mise to compile Python from source
apt_build_deps=(
  build-essential
  libssl-dev
  zlib1g-dev
  libbz2-dev
  libreadline-dev
  libsqlite3-dev
  libncursesw5-dev
  xz-utils
  tk-dev
  libxml2-dev
  libxmlsec1-dev
  libffi-dev
  liblzma-dev
)

apt_deps=(
  ruff
  pipx
)

link() {
  mklink config/flake8 $XDG_CONFIG_HOME
}

install() {
  # Install Python build dependencies so mise can compile Python from source
  case $(_os) in
    macos)
      brew install ${brew_deps[@]}
      ;;
    debian)
      sudo apt update
      sudo apt install -y ${apt_build_deps[@]} ${apt_deps[@]}
      ;;
  esac

  pipx install ${pipx_deps[@]}
  echo-note "Set your global Python version via: mise use --global python@latest"
}

update() {
  case $(_os) in
    macos)
      brew install ${brew_deps[@]}
      brew upgrade ${brew_deps[@]}
      ;;
    debian)
      sudo apt install -y ${apt_deps[@]}
      ;;
  esac

  pipx upgrade-all
}

clean() {
  rm -rfv "$XDG_CONFIG_HOME/flake8"
}

init "$@"
