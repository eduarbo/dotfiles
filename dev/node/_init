#!/usr/bin/env zsh
source ${0:A:h}/../../deploy
source env.zsh

# npm packages to install globally
global_npm_packages=(
  pyright # Python language server (avoids adding nodeenv just for this)
)

link() {
  mklink prettierrc.js "$HOME/.prettierrc.js"
}

install() {
  case $(_os) in
    macos)
      brew install pnpm
      ;;
    debian)
      # pnpm installs itself once node is available via mise
      npm install -g pnpm
      ;;
  esac

  npm install -g ${global_npm_packages[@]}
}

update() {
  npm update -g ${global_npm_packages[@]}
  case $(_os) in
    macos)
      brew upgrade pnpm
      ;;
    debian)
      npm install -g pnpm
      ;;
  esac
}

clean() {
  rm -rfv "$HOME/.prettierrc.js"
}

init "$@"
