#!/usr/bin/env zsh
source ${0:A:h}/../../deploy

brew_deps=(
  btop
  hacker1024/hacker1024/coretemp
  gnu-typist
  vapoursynth-mvtools
  p7zip
  tree
  wget
  ffmpeg
  ffms2
  prettyping
  yt-dlp
)

cask_deps=(
  raycast
  codex
  telegram
  whatsapp
  craft
  syncthing-app
  iina
  iptvnator
  adobe-acrobat-reader
  android-file-transfer
  appcleaner
  bruno
  grandperspective
  keka
  keycastr
  omnidisksweeper
  qlmarkdown
  quicklook-video
  skim
  suspicious-package
  visual-studio-code
)

# ARM-only casks
if [[ "$(uname -m)" == "arm64" ]]; then
  cask_deps+=(
    orbstack
  )
fi

# link() {}

install() {
  case $(_os) in
    macos)
      # Homebrew 6+ prompts to trust non-official taps; pre-trust to keep installs non-interactive
      brew trust --tap hacker1024/hacker1024 teamookla/speedtest
      for pkg in "${brew_deps[@]}"; do
        brew install "$pkg"
      done
      for pkg in "${cask_deps[@]}"; do
        brew install --cask "$pkg"
      done
      brew tap teamookla/speedtest
      brew install speedtest
      ;;
  esac
}

update() {
  install
}

# clean() {}

init "$@"
