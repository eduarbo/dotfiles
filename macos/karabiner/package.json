{
  "name": "karabiner-elements-config-generator",
  "version": "2.0.0",
  "description": "TypeScript-based Karabiner-Elements configuration generator",
  "type": "module",
  "main": "dist/config/karabiner.js",
  "scripts": {
    "build": "tsc && node --enable-source-maps dist/scripts/build.js json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prettier": "prettier config lib scripts --write"
  },
  "keywords": [
    "karabiner-elements",
    "karabiner",
    "json",
    "typescript",
    "keyboard"
  ],
  "author": "Eduardo Ruiz Macias <eduarbo@gmail.com>",
  "license": "GPL-3.0-or-later",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
